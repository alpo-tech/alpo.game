[Unit]
Description=Alpo Sea Battle
After=network.target

[Service]
Type=simple
User=alpo-game
Group=alpo-game
WorkingDirectory=/opt/alpo-game/current
ExecStart=/opt/alpo-game/current/alpo-game
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
